{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "pengumuman",
        "berita"
      ]
    },
    "image": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "date",
    "summary",
    "type"
  ]
}