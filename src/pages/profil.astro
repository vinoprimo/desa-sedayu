---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Profil Desa" description="Profil singkat Desa Sedayu, Kecamatan Jumantono, Kabupaten Karanganyar.">
  <section class="section page-header">
    <div class="section-inner">
      <p class="eyebrow">Profil</p>
      <h1>Desa Sedayu, Jumantono, Karanganyar</h1>
      <p class="lead">Halaman ini memuat identitas desa, sejarah singkat, wilayah, dan potensi utama desa.</p>
    </div>
  </section>
  <section class="section">
    <div class="section-inner two-col">
      <aside class="card">
        <h3>Data singkat</h3>
        <p class="muted">Konten ini dapat dilengkapi setelah data resmi desa tersedia.</p>
        <ul class="list">
          <li>Kecamatan: Jumantono</li>
          <li>Kabupaten: Karanganyar</li>
          <li>Provinsi: Jawa Tengah</li>
          <li>Kode Pos: 57782</li>
        </ul>
      </aside>
      <div>
        <h2>Mandiri pangan dan potensi lokal</h2>
        <p>Desa Sedayu dikenal memiliki potensi pertanian, perkebunan, dan peternakan. Website ini dapat menjadi tempat untuk memperkenalkan komoditas unggulan, kegiatan warga, UMKM, dan program pembangunan desa.</p>
        <p>Bagian profil sebaiknya diperbarui dengan data resmi desa terbaru, termasuk peta wilayah, jumlah dusun, data penduduk ringkas, dan potensi ekonomi lokal.</p>
      </div>
    </div>
  </section>
</BaseLayout>
