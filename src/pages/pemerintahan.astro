---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Pemerintahan" description="Informasi pemerintahan Desa Sedayu.">
  <section class="section page-header">
    <div class="section-inner">
      <p class="eyebrow">Pemerintahan</p>
      <h1>Struktur, lembaga, dan tata kelola desa.</h1>
      <p class="lead">Satu halaman ringkas untuk membantu warga mengenal perangkat desa dan lembaga yang melayani masyarakat.</p>
    </div>
  </section>
  <section class="section">
    <div class="section-inner grid">
      <article class="card">
        <h3>Visi dan Misi</h3>
        <p class="muted">Tempatkan visi misi resmi desa yang masih berlaku agar menjadi rujukan publik.</p>
      </article>
      <article class="card">
        <h3>Struktur Organisasi</h3>
        <p class="muted">Daftar Kepala Desa, Sekretaris Desa, Kaur, Kasi, Kadus, dan perangkat terkait.</p>
      </article>
      <article class="card">
        <h3>Lembaga Desa</h3>
        <p class="muted">BPD, LPMD, PKK, LINMAS, dan lembaga lain dapat dijelaskan secara singkat di sini.</p>
      </article>
    </div>
  </section>
</BaseLayout>
